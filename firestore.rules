rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == studentId;
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /evaluations/{evaluationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.resource.data.studentId == request.auth.uid;
    }

    match /studentSubjects/{assignmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.resource.data.studentId == request.auth.uid;
    }

    // Curriculum catalogs and the old -> new equivalency registry.
    match /new_subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /old_subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /curriculum_mappings/{oldCourseCode} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Finalized evaluations are locked, timestamped snapshots. They may be created
    // and read, never edited or removed — a correction is a new evaluation record.
    match /evaluation_history/{evaluationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}